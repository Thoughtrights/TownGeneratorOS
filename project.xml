<?xml version="1.0" encoding="utf-8"?>
<project>
	
	<meta title="Medieval Town Map" package="com.watabou.towngenerator" version="0.0.2"/>
	<app main="com.watabou.towngenerator.Main" path="Export" file="TownGenerator" />
	
	<source path="Source" />

	<haxelib name="lime" version="7.8.0" />
	<haxelib name="openfl" version="9.0.2" />
	<haxelib name="msignal" version="1.2.5" />

	<!-- General -->
	<window background="transparent" fps="120" vsync="true" hardware="true" allow-high-dpi="true"/>
	<!-- Desktop -->
	<window width="800" height="800" fullscreen="false" resizable="true" borderless="false" if="desktop"/>
	<!-- Mobile -->
	<window width="0" height="0" fullscreen="true" orientation="portrait" if="mobile" />

	<icon path="Assets/favicon.ico" />
	<assets path="Assets">
		<image path="maroubra.png" id="font" />
	</assets>

	<!-- Custom shell page: blocks Lime's devicemotion/deviceorientation
	     listener registrations (this app reads no motion sensors), so
	     embedding the map in an iframe doesn't spam Permissions-Policy
	     violations in the console. -->
	<template path="templates/html5/index.html" rename="index.html" if="html5" />
	
</project>
